  "tokenColors": [
    {
      "name": "Global / Comment",
      "scope": "comment, comment.block, comment.line, comment.block.documentation",
      "settings": {
        "foreground": "#413C48",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": "string, string.quoted, string.regexp, string.template",
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "String Escape",
      "scope": "constant.character.escape, constant.character.entity",
      "settings": { "foreground": "#DBCEE1" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric, constant.numeric.float, constant.numeric.integer, constant.numeric.hex",
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "Boolean",
      "scope": "constant.language.boolean, constant.language.null, constant.language.undefined",
      "settings": { "foreground": "#ff9cac" }
    },
    {
      "name": "Keyword",
      "scope": "keyword, keyword.control, keyword.operator, keyword.other",
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Keyword Other",
      "scope": "keyword.other.unit, keyword.other.special-method",
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "Storage / Modifier",
      "scope": "storage, storage.type, storage.modifier, storage.control",
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "Function call",
      "scope": "entity.name.function, entity.name.function.call, support.function, support.function.builtin, meta.function-call",
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Function definition",
      "scope": "meta.function entity.name.function, meta.definition.method entity.name.function, meta.method.declaration entity.name.function",
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Class method",
      "scope": "meta.definition.method entity.name.function, meta.method.return-type entity.name.type",
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "Class variable",
      "scope": "variable.object.property, meta.field.declaration entity.name.function, variable.other.object.property",
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "Type / Class",
      "scope": "entity.name.type, entity.name.type.class, entity.other.inherited-class, support.type, support.class, meta.class",
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Variable",
      "scope": "variable, variable.parameter, variable.language, variable.other, meta.definition.variable, support.variable, support.constant",
      "settings": { "foreground": "#DBCEE1" }
    },
    {
      "name": "Variable parameter",
      "scope": "variable.parameter, variable.parameter.function.language",
      "settings": {
        "foreground": "#DBCEE1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Modules / Imports",
      "scope": "support.module, support.node, entity.name.module",
      "settings": {
        "foreground": "#f07178",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant language",
      "scope": "constant.language, constant.language.symbol, keyword.other.special-method, constant.other.key",
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Constant placeholder",
      "scope": "constant.other.placeholder",
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation, punctuation.definition, punctuation.separator, punctuation.terminator, punctuation.accessor, punctuation.bracket",
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Delimiter / Comma / Semicolon",
      "scope": "punctuation.definition.separator, punctuation.separator.comma, punctuation.terminator.statement",
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Operator",
      "scope": "keyword.operator, keyword.operator.arithmetic, keyword.operator.comparison, keyword.operator.assignment, keyword.operator.logical",
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Template expression",
      "scope": "template.expression, template.expression.begin, template.expression.end, punctuation.definition.template-expression",
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Embedded content reset",
      "scope": "meta.embedded, meta.template.expression, source.groovy.embedded",
      "settings": { "foreground": "#DBCEE1" }
    },
    {
      "name": "YAML / TOML keys",
      "scope": "entity.name.tag.yaml, support.type.property-name.toml",
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "JSON key",
      "scope": "meta.object-literal.key, meta.object-literal.key string, support.type.property-name.json",
      "settings": { "foreground": "#f07178" }
    },
    {

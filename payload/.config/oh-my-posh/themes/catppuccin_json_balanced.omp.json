{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",

  // --- palette: colores Catppuccin ---
  "palette": {
    "os": "#ACB0BE",
    "closer": "p:os",
    "pink": "#F4B8E4",
    "lavender": "#BABBF1",
    "blue": "#8CAAEE"
  },

  // --- blocks: prompt principal (linea 1) ---
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:closer",
          "style": "plain",
          "template": "> ",
          "type": "text"
        },
        {
          "foreground": "p:pink",
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path",
          "properties": {
            "folder_icon": "....",
            "home_icon": "~",
            "style": "full"
          }
        },
        {
          "foreground": "p:lavender",
          "style": "plain",
          "template": "{{ .HEAD }} ",
          "type": "git",
          "properties": {
            "branch_icon": " ",
            "cherry_pick_icon": " ",
            "commit_icon": " ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": " ",
            "no_commits_icon": " ",
            "rebase_icon": " ",
            "revert_icon": " ",
            "tag_icon": " "
          }
        }
      ],
      "type": "prompt"
    },

    // --- blocks: linea de entrada (flecha) ---
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:closer",
          "style": "plain",
          "template": "",
          "type": "text"
        }
      ],
      "type": "prompt"
    },

    // --- blocks: rprompt (tiempo de ejecucion) ---
    {
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "foreground": "p:lavender",
          "properties": {
            "always_enabled": true,
            "style": "austin",
            "threshold": 0
          },
          "style": "plain",
          "template": " {{ .FormattedMs }}",
          "type": "executiontime"
        }
      ],
      "type": "rprompt"
    }
  ],

  // --- opciones globales ---
  "final_space": true,
  "version": 4
}

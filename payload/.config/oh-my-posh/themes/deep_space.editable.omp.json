{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "text": "#b8cdfe",
    "dim": "#444b6f",
    "blue": "#4961da",
    "violet": "#7c5cff",
    "cyan": "#67c9e4",
    "warn": "#e0af68",
    "closer": "#67c9e4"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:cyan",
          "template": "> "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:violet",
          "template": "{{ .Path }} ",
          "properties": {
            "style": "full",
            "home_icon": "~",
            "folder_icon": "..\ue5fe.."
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:blue",
          "template": "{{ .HEAD }} ",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": false,
            "fetch_upstream_icon": false
          }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:closer",
          "template": "\uf178"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:dim",
          "template": "\uf0e7 {{ .FormattedMs }}",
          "properties": {
            "threshold": 0,
            "style": "austin",
            "always_enabled": true
          }
        }
      ]
    }
  ],
  "final_space": true,
  "version": 3
}

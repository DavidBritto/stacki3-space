#!/usr/bin/env bash
set -euo pipefail

kitty_bin="${STACK_KITTY_BIN:-kitty}"
main_conf="${HOME}/.config/kitty/kitty.conf"
panel_conf="${HOME}/.config/kitty/panel.conf"

if ! command -v "$kitty_bin" >/dev/null 2>&1; then
  echo "stack-terminal: kitty not found in PATH" >&2
  exit 127
fi

mode="${1:-}"
case "$mode" in
  main)
    shift
    exec "$kitty_bin" --config "$main_conf" --class stack-main-terminal --title "1:terminal" \
      -- bash -lc 'exec tmux new-session -A -s main' "$@"
    ;;
  panel)
    shift
    exec "$kitty_bin" --config "$panel_conf" "$@"
    ;;
  ''|interactive)
    exec "$kitty_bin" --config "$main_conf" -- \
      bash -lc 'export STACK_NO_AUTO_TMUX=1; exec ${SHELL:-bash} -l'
    ;;
  *)
    exec "$kitty_bin" --config "$main_conf" "$@"
    ;;
esac

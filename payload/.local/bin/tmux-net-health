#!/usr/bin/env bash
set -euo pipefail

CACHE_FILE="/tmp/tmux-net-health-${UID}.cache"
TTL=15

if [[ -f "$CACHE_FILE" ]]; then
  now=$(date +%s)
  mtime=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)
  if (( now - mtime < TTL )); then
    cat "$CACHE_FILE"
    exit 0
  fi
fi

ip_addr=$(hostname -I 2>/dev/null | awk '{print $1}' || true)
[[ -n "${ip_addr:-}" ]] || ip_addr="no-ip"

latency_raw=$( (ping -n -c1 -W1 8.8.8.8 2>/dev/null | awk -F'time=' 'NF>1 {print $2}' | awk '{print $1}' | head -n1) || true )
if [[ -n "${latency_raw:-}" ]]; then
  latency="$(printf '%.0fms' "${latency_raw%.*}" 2>/dev/null || true)"
else
  latency="down"
fi

printf "%s | %s\n" "$ip_addr" "$latency" | tee "$CACHE_FILE"

#!/usr/bin/env bash
set -euo pipefail

panel="${1:-}"
[ -n "$panel" ] || exit 1

panel_width=1040
panel_height=640
window_class="stack-panel"

if ! command -v kitty >/dev/null 2>&1; then
  exit 0
fi

case "$panel" in
  htop|btop)
    title="TUI: htop"
    cmd="if command -v htop >/dev/null 2>&1; then exec htop; else exec top; fi"
    ;;
  lazygit)
    title="TUI: lazygit"
    cmd="if command -v lazygit >/dev/null 2>&1; then exec lazygit; else printf 'lazygit no esta instalado en PATH\\n'; printf 'Presiona una tecla para abrir una shell en este repo...'; IFS= read -rsn1 _; export STACK_NO_AUTO_TMUX=1; exec \${SHELL:-bash} -l; fi"
    ;;
  lazyjournal|logs)
    title="TUI: logs · lazyjournal"
    cmd="if command -v lazyjournal >/dev/null 2>&1; then exec lazyjournal; else printf 'lazyjournal no esta instalado en PATH\\n'; printf 'Ejecuta scripts/install-lazyjournal.sh desde el repo STACKI3-Space.\\n'; printf 'Presiona una tecla para abrir una shell...'; IFS= read -rsn1 _; export STACK_NO_AUTO_TMUX=1; exec \${SHELL:-bash} -l; fi"
    ;;
  audio-mixer)
    title="TUI: audio"
    cmd="exec alsamixer"
    ;;
  files-yazi)
    title="TUI: files · yazi"
    panel_width=1180
    panel_height=720
    window_class="stack-files-panel"
    cmd="cd \"\${STACK_FILES_DIR:-$HOME}\"; if command -v yazi >/dev/null 2>&1; then exec yazi .; else printf 'yazi no esta instalado en PATH\n'; printf 'Presiona una tecla para abrir shell...'; IFS= read -rsn1 _; exec \${SHELL:-bash} -l; fi"
    ;;
  network-tui)
    title="TUI: network"
    panel_width=780
    panel_height=560
    window_class="stack-network-panel"
    cmd="export STACK_NO_AUTO_TMUX=1; exec $HOME/.config/polybar/scripts/network_tui.sh"
    ;;
  network-nmtui)
    title="TUI: nmtui"
    panel_width=680
    panel_height=440
    window_class="stack-network-panel"
    cmd="export STACK_NO_AUTO_TMUX=1 TERM=xterm-256color; export NEWT_COLORS='root=white,black;border=blue,black;window=white,black;shadow=black,black;title=magenta,black;button=black,blue;actbutton=black,magenta;entry=white,black;label=white,black;compactbutton=white,black;checkbox=blue,black;actcheckbox=black,blue'; exec nmtui"
    ;;
  bluetooth-tui)
    title="TUI: bluetooth"
    panel_width=720
    panel_height=520
    window_class="stack-bluetooth-panel"
    cmd="exec $HOME/.config/polybar/scripts/bluetooth_tui.sh"
    ;;
  clipboard-view)
    title="TUI: clipboard"
    cmd="greenclip print | less -R"
    ;;
  quick-notes)
    title="TUI: notes"
    cmd="mkdir -p ~/.local/state/desk && if command -v nano >/dev/null 2>&1; then exec nano ~/.local/state/desk/quick-notes.txt; else exec \${EDITOR:-vi} ~/.local/state/desk/quick-notes.txt; fi"
    ;;
  *)
    exit 1
    ;;
esac

if i3-msg -t get_tree | python3 -c 'import json, sys; want = sys.argv[1]; tree = json.load(sys.stdin); stack=[tree]; found=False
while stack:
    node=stack.pop()
    if node.get("name") == want:
        found=True
        break
    stack.extend(node.get("nodes", [])); stack.extend(node.get("floating_nodes", []))
print("yes" if found else "no")' "$title" | grep -qx yes; then
  exec i3-msg "[title=\"$title\"] scratchpad show, resize set $panel_width $panel_height, move position center, focus" >/dev/null 2>&1
else
  "$HOME/.local/bin/stack-terminal" panel --class "$window_class" --title "$title" \
    --working-directory "$HOME" \
    bash --noprofile --norc -c "export STACK_NO_AUTO_TMUX=1; $cmd; rc=\$?; if [ \$rc -ne 0 ]; then printf '\n[panel error] exit=%s\n' \"\$rc\"; printf 'Presiona una tecla para cerrar...'; IFS= read -rsn1 _; fi; exit \$rc">/tmp/stacki3-space-tui-panel.log 2>&1 &
  sleep 0.4
  i3-msg "[title=\"$title\"] floating enable, resize set $panel_width $panel_height, move scratchpad, scratchpad show, move position center, focus" >/dev/null 2>&1 || true
  exit 0
fi

#!/usr/bin/env bash
set -euo pipefail

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

cat >"$tmp" <<'EOF'
[Greeter]
background=__STACKI3_HOME__/Imágenes/wallpapers/wallpaper.jpg
background-color=#131520
theme-name=Breeze-Dark
icon-theme-name=breeze-dark
cursor-theme-name=Bibata-Original-Classic
cursor-theme-size=22
font-name=Noto Sans 10
xft-antialias=true
xft-dpi=96
xft-hintstyle=hintslight
xft-rgba=rgb
draw-grid=false
draw-user-backgrounds=false
content-align=center
show-hostname=false
show-keyboard=true
show-a11y=true
show-clock=true
show-power=true
enable-hidpi=auto
activate-numlock=false
clock-format=%a %d %b, %H:%M
EOF

sudo install -Dm644 "$tmp" /etc/lightdm/slick-greeter.conf
printf 'Slick Greeter actualizado en /etc/lightdm/slick-greeter.conf\n'

#!/usr/bin/env python3
import os
import subprocess
import sys
import time
from pathlib import Path

HOME = Path.home()
CACHE_DIR = HOME / '.cache' / 'stacki3-space'
CACHE_DIR.mkdir(parents=True, exist_ok=True)
CACHE_FILE = CACHE_DIR / 'rofi-files.txt'
CACHE_TTL = 600
ROOTS = [HOME / 'Documentos', HOME / 'Descargas', HOME / 'git', HOME / 'projects', HOME / 'code', HOME / 'Imágenes']
SKIP_DIRS = {'.git', 'node_modules', '.cache', '.venv', 'venv', '__pycache__', 'dist', 'build'}
MAX_DEPTH = 4


def walk_files():
    out = []
    for root in ROOTS:
        if not root.exists() or not root.is_dir():
            continue
        for current_root, dirs, files in os.walk(root):
            path = Path(current_root)
            try:
                depth = len(path.relative_to(root).parts)
            except Exception:
                depth = 0
            dirs[:] = [d for d in dirs if d not in SKIP_DIRS and not d.startswith('.')]
            if depth >= MAX_DEPTH:
                dirs[:] = []
            for name in files:
                if name.startswith('.'):
                    continue
                full = path / name
                label = str(full).replace(str(HOME) + '/', '~/')
                out.append(label)
    return sorted(set(out), key=str.lower)


def ensure_cache(force=False):
    if not force and CACHE_FILE.exists() and time.time() - CACHE_FILE.stat().st_mtime < CACHE_TTL:
        return
    CACHE_FILE.write_text('\n'.join(walk_files()) + '\n')


def open_target(label: str):
    target = Path(label.replace('~', str(HOME), 1)).expanduser()
    if not target.exists():
        return 1
    if target.is_dir():
        return subprocess.call(['kitty', '--class=stack-files-panel', '--title', f'TUI: files · {target.name}', '--working-directory', str(target), 'bash', '--noprofile', '--norc', '-c', 'export STACK_NO_AUTO_TMUX=1; exec yazi . || exec ${SHELL:-bash} -l'])
    return subprocess.call(['xdg-open', str(target)])


retv = int(os.environ.get('ROFI_RETV', '0'))
if retv == 0:
    ensure_cache()
    sys.stdout.write(CACHE_FILE.read_text())
    sys.exit(0)

selection = sys.argv[1] if len(sys.argv) > 1 else ''
if selection == '[actualizar índice]':
    ensure_cache(force=True)
    sys.exit(0)
if selection:
    sys.exit(open_target(selection))
